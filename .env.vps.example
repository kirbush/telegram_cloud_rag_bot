BOT_TOKEN=
BOT_INSTANCE_NAME=main
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
WEBHOOK_BASE_URL=
USE_WEBHOOK=false
LOG_LEVEL=INFO

# NotebookLM integration for a separate VPS instance.
NOTEBOOKLM_ENABLED=true
NOTEBOOKLM_STORAGE_STATE=~/.notebooklm/storage_state.json
NOTEBOOKLM_DEFAULT_NOTEBOOK=
NOTEBOOKLM_NOTEBOOK_MAP={}
NOTEBOOKLM_RUNTIME_STATE_PATH=.state/notebooklm/runtime_state.json
NOTEBOOKLM_RUNTIME_STORAGE_STATE=.state/notebooklm/storage_state.json
NOTEBOOKLM_AUTH_ACCOUNT_KEY=
NOTEBOOKLM_SHARED_STORAGE_STATE=
NOTEBOOKLM_ADMIN_USERNAME=admin
NOTEBOOKLM_ADMIN_PASSWORD=
NOTEBOOKLM_REMOTE_AUTH_BASE_URL=https://example.com
NOTEBOOKLM_UPLOAD_SESSION_STATE_PATH=.state/notebooklm/upload_sync_state.json
NOTEBOOKLM_UPLOAD_SESSION_TTL_SECONDS=900
NOTEBOOKLM_UPLOAD_REFRESH_TTL_SECONDS=2592000
NOTEBOOKLM_WINDOWS_HELPER_PROTOCOL_SCHEME=tgctxbot-notebooklm-sync

BOT_ADMIN_USER_IDS=123456789
BOT_ACCESS_STATE_PATH=.state/bot/main-access.sqlite3
BOT_CONVERSATION_STATE_PATH=.state/bot/main-conversations.sqlite3
UPTIME_KUMA_PUBLIC_URL=
TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_URL=
NOTEBOOKLM_PROXY_ENABLED=false
NOTEBOOKLM_PROXY_URL=
NOTEBOOKLM_TIMEOUT=180
NOTEBOOKLM_REFRESH_CMD=
NOTEBOOKLM_VPS_LIGHTWEIGHT_MODE=true
NOTEBOOKLM_COOKIE_KEEPALIVE_INTERVAL_SECONDS=420
NOTEBOOKLM_REMOTE_AUTH_MEMORY_LIMIT_MB=1024
NOTEBOOKLM_REMOTE_AUTH_MEMORY_SWAP_LIMIT_MB=1024
MEDIA_CONTEXT_ENABLED=false
REACTION_CONTEXT_ENABLED=false
OPENAI_VISION_MODEL=gpt-5.4-nano
MEDIA_CONTEXT_TIMEOUT_SECONDS=60
MEDIA_CONTEXT_MAX_RETRIES=2
NOTEBOOKLM_SOURCE_SYNC_STATE_PATH=.state/notebooklm/source_sync_state.json
NOTEBOOKLM_SOURCE_SYNC_EXPORT_DIR=.state/notebooklm/exports
NOTEBOOKLM_SOURCE_SYNC_BOOTSTRAP_CUTOFF_DATE=2026-04-10
NOTEBOOKLM_SOURCE_SYNC_MAX_WORDS_PER_SOURCE=500000
NOTEBOOKLM_SOURCE_SYNC_MAX_SOURCES_PER_NOTEBOOK=50
NOTEBOOKLM_SOURCE_SYNC_ENABLED=true
NOTEBOOKLM_BACKGROUND_SYNC_ENABLED=false
NOTEBOOKLM_BACKGROUND_SYNC_TIMEZONE=Europe/Moscow
NOTEBOOKLM_BACKGROUND_SYNC_HOUR=3
NOTEBOOKLM_BACKGROUND_SYNC_MINUTE=0
BOT_GROUP_TRIGGER_PIPELINE=notebooklm
BOT_SYNC_INDEXING=false
