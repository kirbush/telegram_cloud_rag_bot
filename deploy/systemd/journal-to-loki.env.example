# Optional environment for a journal-to-Loki forwarder.
# Keep this off by default; it is meant for the VPS host, not the app container.

JOURNAL_TO_LOKI_URL=https://loki.example.com/loki/api/v1/push
JOURNAL_TO_LOKI_LABELS=job=tgctxbot,env=vps
JOURNAL_TO_LOKI_UNITS=notebooklm-google-ssh-tunnel.service,workplace-telegram-ssh-tunnel.service,tgctxbot-tunnel-watchdog.service
JOURNAL_TO_LOKI_INTERVAL_SECONDS=30
