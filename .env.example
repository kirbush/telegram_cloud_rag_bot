# Telegram NotebookLM Bot — local example
# Copy this file to `.env` and fill real values locally.
# Never commit real tokens, passwords, cookies, storage state, or chat exports.

BOT_TOKEN=replace-me
BOT_INSTANCE_NAME=example
BOT_ADMIN_USER_IDS=123456789

TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_URL=
TELEGRAM_CHAT_ALIAS_MAP=

NOTEBOOKLM_ENABLED=true
NOTEBOOKLM_STORAGE_STATE=/var/lib/tgctxbot/notebooklm/storage_state.json
NOTEBOOKLM_RUNTIME_STATE_PATH=/var/lib/tgctxbot/notebooklm/runtime_state.json
NOTEBOOKLM_RUNTIME_STORAGE_STATE=/var/lib/tgctxbot/notebooklm/runtime_storage_state.json
NOTEBOOKLM_DEFAULT_NOTEBOOK=
NOTEBOOKLM_NOTEBOOK_MAP={}
NOTEBOOKLM_TIMEOUT=60

NOTEBOOKLM_ADMIN_USERNAME=admin
NOTEBOOKLM_ADMIN_PASSWORD=change-me-long-random
NOTEBOOKLM_ADMIN_BIND_HOST=127.0.0.1

NOTEBOOKLM_PROXY_ENABLED=false
NOTEBOOKLM_PROXY_URL=

NOTEBOOKLM_SOURCE_SYNC_ENABLED=true
NOTEBOOKLM_SOURCE_SYNC_STATE_PATH=.state/notebooklm/source_sync_state.json
NOTEBOOKLM_SOURCE_SYNC_EXPORT_DIR=.state/notebooklm/exports
NOTEBOOKLM_SOURCE_SYNC_BOOTSTRAP_CUTOFF_DATE=2026-04-10
NOTEBOOKLM_SOURCE_SYNC_MAX_WORDS_PER_SOURCE=500000
NOTEBOOKLM_SOURCE_SYNC_MAX_SOURCES_PER_NOTEBOOK=50
NOTEBOOKLM_BACKGROUND_SYNC_ENABLED=false
NOTEBOOKLM_BACKGROUND_SYNC_TIMEZONE=Europe/Moscow
NOTEBOOKLM_BACKGROUND_SYNC_HOUR=3
NOTEBOOKLM_BACKGROUND_SYNC_MINUTE=0

NOTEBOOKLM_LIGHTWEIGHT_HISTORY_PATH=.state/notebooklm/history.sqlite3
BOT_ACCESS_STATE_PATH=.state/bot/access.sqlite3
BOT_CONVERSATION_STATE_PATH=.state/bot/conversations.sqlite3
NOTEBOOKLM_HEALTH_CACHE_SECONDS=30
NOTEBOOKLM_READY_STORAGE_MAX_AGE_DAYS=14
NOTEBOOKLM_READY_SYNC_MAX_AGE_HOURS=36
NOTEBOOKLM_SYNC_TICKS_PATH=.state/notebooklm/sync_ticks.jsonl
NOTEBOOKLM_SYNC_TICK_RETENTION_DAYS=30
NOTEBOOKLM_BOT_UNAVAILABLE_COOLDOWN_MINUTES=5
NOTEBOOKLM_JANITOR_ENABLED=true
NOTEBOOKLM_JANITOR_INTERVAL_SECONDS=60
NOTEBOOKLM_COOKIE_KEEPALIVE_INTERVAL_SECONDS=420

NOTEBOOKLM_REMOTE_AUTH_BASE_URL=
NOTEBOOKLM_REMOTE_AUTH_STATE_PATH=.state/notebooklm/auth_sessions.json
NOTEBOOKLM_REMOTE_AUTH_TTL_SECONDS=900
NOTEBOOKLM_REMOTE_AUTH_POLL_SECONDS=5
NOTEBOOKLM_REMOTE_AUTH_MEMORY_LIMIT_MB=1024
NOTEBOOKLM_REMOTE_AUTH_MEMORY_SWAP_LIMIT_MB=1024
NOTEBOOKLM_REMOTE_AUTH_DOCKER_SOCKET=/var/run/docker.sock
NOTEBOOKLM_REMOTE_AUTH_SELENIUM_IMAGE=selenium/standalone-chromium:4.34.0
NOTEBOOKLM_REMOTE_AUTH_NOVNC_PORT=47900

NOTEBOOKLM_UPLOAD_SESSION_STATE_PATH=.state/notebooklm/upload_sync_state.json
NOTEBOOKLM_UPLOAD_SESSION_TTL_SECONDS=900
NOTEBOOKLM_UPLOAD_REFRESH_TTL_SECONDS=2592000
NOTEBOOKLM_WINDOWS_HELPER_PROTOCOL_SCHEME=tgctxbot-notebooklm-sync

BOT_NLM_SHOW_SOURCES=false
BOT_REPLY_IN_DIRECT_MESSAGES_TOPIC=false
MEDIA_CONTEXT_ENABLED=false
REACTION_CONTEXT_ENABLED=false
MEDIA_CONTEXT_TIMEOUT_SECONDS=60.0
MEDIA_CONTEXT_MAX_RETRIES=2

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-nano

USE_WEBHOOK=false
WEBHOOK_BASE_URL=
LOG_LEVEL=INFO
